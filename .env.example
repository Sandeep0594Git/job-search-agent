# Copy this file to .env for local runs. In GitHub, add these as
# Settings -> Secrets and variables -> Actions -> New repository secret.

# --- Telegram (required) ---
# 1. In Telegram, message @BotFather -> /newbot -> copy the token
# 2. Message your new bot once (say "hi"), then open
#    https://api.telegram.org/bot<TOKEN>/getUpdates and copy chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- WhatsApp via CallMeBot (optional mirror) ---
# Add +34 644 66 32 62 to your WhatsApp contacts and send it:
#   "I allow callmebot to send me messages"
# It replies with your personal apikey.
CALLMEBOT_PHONE=+91XXXXXXXXXX
CALLMEBOT_APIKEY=

# --- Gemini (required for /tailor resume generation) ---
# Free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Optional: baseline resume as base64 (only if repo is public and you
#     don't want your resume file in the repo). Otherwise just put the file
#     in the resume/ folder. ---
# PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("resume.pdf")) | Set-Clipboard
RESUME_B64=
RESUME_EXT=pdf
